# Django (required for runserver; use strong secret in production)
SECRET_KEY=your-secret-key-at-least-50-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# Docker(`docker compose`): UIлҠ” http://localhost:8080 вҖ” composeк°Җ `ALLOWED_HOSTS`м—җ api,127.0.0.1 л“ұмқ„ л„ЈмқҢ.
# DB/RAG мҳҒмҶҚ кІҪлЎңлҠ” composeмқҳ `SQLITE_PATH`, `CHROMA_PERSIST_DIR`к°Җ мҡ°м„ (лЎңм»¬ runserverлҠ” кё°ліё backend/db.sqlite3).

# Azure OpenAI (required for chat, agent, RAG, analyze)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_FAST_DEPLOYMENT_NAME=gpt-4o-mini
AZURE_OPENAI_MAP_FILTER_DEPLOYMENT_NAME=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-small
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# SAP HTTP (TR list, dependency snapshot)
SAP_HTTP_URL=
SAP_CLIENT=
SAP_USER=
SAP_PASSWD=

# SAP ADT (optional; for mcp-abap-adt)
SAP_ADT_HOST=
SAP_ADT_USER=
SAP_ADT_PASSWORD=
SAP_ADT_CLIENT=
SAP_ADT_LANGUAGE=EN

# External MCP (optional; leave empty to disable)
# SAP Assistantм—җ Docs/ADT лҸ„кө¬к°Җ м•Ҳ л¶ҷмңјл©ҙ URLмқҙ л№„м–ҙ мһҲлҠ” кІғмһ…лӢҲлӢӨ. Djangoл§Ң мјңлҸ„ MCP м„ңлІ„лҠ” мһҗлҸҷ кё°лҸҷлҗҳм§Җ м•ҠмқҢ.
# Docs мҳҲмӢң(ABAP л¬ём„ң, Streamable HTTP): https://mcp-abap.marianzeis.de/mcp вҖ” мғҒм„ё: docs/EXTERNAL_SAP_MCP.md
EXTERNAL_SAP_MCP_DOCS_ABAP_URL=
EXTERNAL_SAP_MCP_DOCS_FULL_URL=
# ADT(GetClass/GetTable)лҠ” лі„лҸ„ н”„лЎңм„ёмҠӨлЎң HTTP MCP лқ„мҡҙ л’Ө URL м§Җм •
EXTERNAL_SAP_MCP_ADT_URL=
EXTERNAL_SAP_MCP_ADT_TOOLS=GetClass,GetTable
# HTTPS MCPм—җм„ң SSL кІҖмҰқ мӢӨнҢЁ(self-signed / кё°м—… н”„лЎқмӢң) мӢңм—җл§Ң false (л№„к¶ҢмһҘ)
# EXTERNAL_SAP_MCP_VERIFY_SSL=false

# RAG (optional)
CHROMA_PERSIST_DIR=
RAG_COLLECTION_NAME=cts_bundler_kb
RAG_INGEST_MAX_DOCS=3000
RAG_DEFAULT_K=5
RAG_QUERY_MAX_K=20
MCP_RAG_QUERY_MAX_K=10

# LLM budgets (see ../docs/LLM_BUDGETS.md)
LLM_CODE_REVIEW_MAX_TOKENS=2500
LLM_CODE_REVIEW_TEMPERATURE=0.1
LLM_AGENT_TEMPERATURE=0
LLM_AGENT_RECURSION_LIMIT=25
LLM_SIMPLE_CHAT_TEMPERATURE=0.2
LLM_CHAT_RAG_TEMPERATURE=0.2
LLM_RAG_CHAIN_TEMPERATURE=0.2
CHAT_RAG_CACHE_TTL_SEC=300
ANALYZE_GRAPH_RECURSION_LIMIT=22
# л°°нҸ¬ мӢ¬мқҳ Researcher л…ёл“ң: Chroma top-k (CRAG 1лӢЁкі„)
# DEPLOY_RESEARCH_RAG_K=6
# лІЎн„° RAG(Researcher) м „мІҙ лҒ„кё° / CRAG LLM нҢҗм •л§Ң лҒ„кё°(кІҖмғүмқҖ мң м§Җ)
# DEPLOY_RESEARCH_RAG_ENABLED=true
# DEPLOY_CRAG_JUDGE_ENABLED=true
# л°°нҸ¬ мӢ¬мқҳ Self-RAG(2лӢЁкі„): м•„нӮӨн…ҚнҠё ліҙкі м„ң к·јкұ° кІҖмҰқВ·1нҡҢ ліҙм • (falseл©ҙ мғқлһө)
# DEPLOY_SELF_RAG_ENABLED=true
# л°°нҸ¬ мӢ¬мқҳ GraphRAG(3лӢЁкі„): TR мӢңл“ң вҶ’ DependencySnapshot к°„м„  (falseл©ҙ мғқлһө)
# DEPLOY_GRAPH_RAG_ENABLED=true
# DEPLOY_GRAPH_RAG_MAX_EDGES=100
# DEPLOY_GRAPH_RAG_MAX_HOPS=1
# DEPLOY_GRAPH_RAG_MAX_SEEDS=100
LLM_MAP_FILTER_MAX_TOKENS=2500
LLM_MAP_FILTER_TEMPERATURE=0.1

# Logging: DEBUG|INFO|WARNING|ERROR|CRITICAL
CTS_LOG_LEVEL=INFO

# LangSmith / LangChain tracing (optional)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=cts-bundler

# Token Dashboard (/api/usage-stats/, UI) вҖ” мӮ¬мҡ©лҹүмқҖ DB(api_llmusagerecord)м—җ лҲ„м Ғ
LLM_USAGE_TRACKING_ENABLED=true
LLM_USAGE_RECENT_MAX=200
# к°ңл°ң мӢңм—җл§Ң: POST /api/usage-stats/reset/
# USAGE_STATS_ALLOW_RESET=true
