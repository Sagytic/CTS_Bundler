# Django (required for runserver; use strong secret in production)
SECRET_KEY=your-secret-key-at-least-50-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# Docker(`docker compose`): UI는 http://localhost:8080 — compose가 `ALLOWED_HOSTS`에 api,127.0.0.1 등을 넣음.
# DB/RAG 영속 경로는 compose의 `SQLITE_PATH`, `CHROMA_PERSIST_DIR`가 우선(로컬 runserver는 기본 backend/db.sqlite3).

# Azure OpenAI (required for chat, agent, RAG, analyze)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_FAST_DEPLOYMENT_NAME=gpt-4o-mini
AZURE_OPENAI_MAP_FILTER_DEPLOYMENT_NAME=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-small
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# SAP HTTP (TR list, dependency snapshot)
SAP_HTTP_URL=
SAP_CLIENT=
SAP_USER=
SAP_PASSWD=

# SAP ADT (optional; for mcp-abap-adt)
SAP_ADT_HOST=
SAP_ADT_USER=
SAP_ADT_PASSWORD=
SAP_ADT_CLIENT=
SAP_ADT_LANGUAGE=EN

# External MCP (optional; leave empty to disable)
# SAP Assistant에 Docs/ADT 도구가 안 붙으면 URL이 비어 있는 것입니다. Django만 켜도 MCP 서버는 자동 기동되지 않음.
# Docs 예시(ABAP 문서, Streamable HTTP): https://mcp-abap.marianzeis.de/mcp — 상세: docs/EXTERNAL_SAP_MCP.md
EXTERNAL_SAP_MCP_DOCS_ABAP_URL=
EXTERNAL_SAP_MCP_DOCS_FULL_URL=
# ADT(GetClass/GetTable)는 별도 프로세스로 HTTP MCP 띄운 뒤 URL 지정
EXTERNAL_SAP_MCP_ADT_URL=
EXTERNAL_SAP_MCP_ADT_TOOLS=GetClass,GetTable
# HTTPS MCP에서 SSL 검증 실패(self-signed / 기업 프록시) 시에만 false (비권장)
# EXTERNAL_SAP_MCP_VERIFY_SSL=false

# RAG (optional)
CHROMA_PERSIST_DIR=
RAG_COLLECTION_NAME=cts_bundler_kb
RAG_INGEST_MAX_DOCS=3000
RAG_DEFAULT_K=5
RAG_QUERY_MAX_K=20
MCP_RAG_QUERY_MAX_K=10

# LLM budgets (see ../docs/LLM_BUDGETS.md)
LLM_CODE_REVIEW_MAX_TOKENS=2500
LLM_CODE_REVIEW_TEMPERATURE=0.1
LLM_AGENT_TEMPERATURE=0
LLM_AGENT_RECURSION_LIMIT=25
LLM_SIMPLE_CHAT_TEMPERATURE=0.2
LLM_CHAT_RAG_TEMPERATURE=0.2
LLM_RAG_CHAIN_TEMPERATURE=0.2
CHAT_RAG_CACHE_TTL_SEC=300
ANALYZE_GRAPH_RECURSION_LIMIT=22
LLM_MAP_FILTER_MAX_TOKENS=2500
LLM_MAP_FILTER_TEMPERATURE=0.1

# Logging: DEBUG|INFO|WARNING|ERROR|CRITICAL
CTS_LOG_LEVEL=INFO

# LangSmith / LangChain tracing (optional)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=cts-bundler

# Token Dashboard (/api/usage-stats/, UI) — 사용량은 DB(api_llmusagerecord)에 누적
LLM_USAGE_TRACKING_ENABLED=true
LLM_USAGE_RECENT_MAX=200
# 개발 시에만: POST /api/usage-stats/reset/
# USAGE_STATS_ALLOW_RESET=true
