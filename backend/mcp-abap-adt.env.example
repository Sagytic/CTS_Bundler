# mcp-abap-adt 프로젝트에서 사용할 .env
#
# 사용법:
#   1. 이 파일 내용을 복사해, mcp-abap-adt 클론 폴더 루트에 .env 로 저장하세요.
#      예: C:\...\mcp-abap-adt\.env
#   2. 또는 터미널에서 (mcp-abap-adt 폴더로 이동 후):
#      copy ..\CTS_Bundelr\backend\mcp-abap-adt.env.example .env
#
# 변수명 매핑 (backend/.env [신 세팅 SAP_Edu] 기준):
#   SAP_ADT_HOST     -> SAP_URL
#   SAP_ADT_USER     -> SAP_USERNAME
#   SAP_ADT_PASSWORD -> SAP_PASSWORD
#   SAP_ADT_CLIENT   -> SAP_CLIENT

# SAP 시스템 URL (ADT 서비스: /sap/bc/adt 활성화 필요)
SAP_URL=http://20.196.144.75:8000

# SAP 로그인
SAP_USERNAME=11355
SAP_PASSWORD=Golive1234!
SAP_CLIENT=200

# 비밀번호에 # 이 있으면 반드시 따옴표로 감싸세요. 예: SAP_PASSWORD="my#pass"
